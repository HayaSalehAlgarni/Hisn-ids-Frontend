# =============================================================================
# Hisn IDS — Frontend (Vite)
# انسخ إلى `frontend/.env` أو `frontend/.env.local` ثم أعد تشغيل npm run dev
# Copy to frontend/.env or frontend/.env.local then restart the dev server.
# =============================================================================

# عنوان خادم Flask (يجب أن يطابق الباكند الذي تشغّله محلياً)
# Must match your Flask server (same host/port as FLASK_HOST / FLASK_PORT in root .env)
VITE_API_BASE_URL=http://127.0.0.1:5000

# Optional: only if analytics API is on another origin. Default: same as Vite proxy → Flask (/api/analytics/*).
# VITE_ANALYTICS_API_URL=http://127.0.0.1:8000
